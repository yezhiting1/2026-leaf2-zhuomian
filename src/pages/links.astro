---
import MainGridLayout from "../layouts/MainGridLayout.astro";
---

<MainGridLayout title="${linksTitle + ' - ' + site.title}">
  <Fragment slot="head">
    <title th:text="${linksTitle + ' - ' + site.title}"></title>
    <style is:global>
      .info-item {
        position: relative;
        padding-left: 1.1rem;
      }
      .info-item::before {
        content: "";
        position: absolute;
        left: 0.25rem;
        top: 50%;
        transform: translateY(-50%);
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background-color: currentColor;
        opacity: 0.4;
      }
      .collapse-icon.is-expanded {
        transform: rotate(180deg);
      }

      /* 折叠面板展开/收起动画 - overflow 和 max-height 由 JS 动态控制 */

      /* 表单输入框边框 - color-mix 混合主题色 */
      #link-submit-form-actual input,
      #link-submit-form-actual textarea,
      #link-submit-form-actual select,
      #link-captcha-canvas,
      #link-captcha-input {
        border-color: color-mix(
          in oklab,
          var(--primary) 22%,
          transparent
        ) !important;
      }
      #link-submit-form-actual input:focus,
      #link-submit-form-actual textarea:focus,
      #link-submit-form-actual select:focus,
      #link-captcha-input:focus {
        border-color: var(--primary) !important;
      }

      /* 单选按钮 - 未选中用极淡主题色背景+彩色边框 */
      .link-type-label:not(:has(input:checked)) {
        background-color: color-mix(
          in oklab,
          var(--primary) 6%,
          transparent
        ) !important;
        color: var(--btn-content) !important;
        font-weight: normal;
        border: 2px solid color-mix(in oklab, var(--primary) 22%, transparent) !important;
      }
      .link-type-label:has(input:checked) {
        background-color: var(--primary) !important;
        color: #fff !important;
        font-weight: bold;
        border: 2px solid var(--primary) !important;
      }
    </style>
  </Fragment>

  <section class="card-base onload-animation mb-4 px-6 py-6 md:px-9">
    <!-- 标题区域 -->
    <div class="mb-6 flex flex-col gap-2">
      <div class="flex items-center justify-between gap-4">
        <div class="flex flex-col gap-2">
          <h1 class="text-3xl font-bold text-90" th:text="${linksTitle}">
            友情链接
          </h1>
          <div class="text-sm text-50">
            <span class="icon-[material-symbols--link-rounded] mr-1"></span>
            <span>Friends links</span>
          </div>
        </div>
      </div>
    </div>

    <!-- 友链列表 -->
    <div th:if="${not #lists.isEmpty(groups)}" class="space-y-8">
      <section
        th:each="group, groupStat : ${groups}"
        th:if="${not #lists.isEmpty(group.links)}"
        th:style="|animation-delay: calc(var(--content-delay) + ${groupStat.index * 50}ms)|"
        class="onload-animation"
      >
        <div class="mb-4 flex items-center justify-between gap-4">
          <h2 class="text-xl font-bold text-90">
            <span th:text="${group.spec.displayName}">Group</span>
          </h2>
          <span
            class="rounded-lg bg-(--btn-regular-bg) px-2.5 py-1 text-xs font-bold text-(--btn-content)"
            th:text="${#lists.size(group.links)}">0</span
          >
        </div>

        <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
          <a
            th:each="link, linkStat : ${group.links}"
            th:href="${link.spec.url}"
            th:title="${link.spec.displayName}"
            th:style="|animation-delay: calc(var(--content-delay) + ${(groupStat.index * 4 + linkStat.index) * 35}ms)|"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-card group min-h-28 items-start! justify-start! gap-4 rounded-xl p-4 text-left active:scale-95"
          >
            <img
              alt=""
              th:if="${not #strings.isEmpty(link.spec.logo)}"
              th:src="${link.spec.logo}"
              th:alt="${link.spec.displayName}"
              loading="lazy"
              class="h-12 w-12 shrink-0 rounded-xl bg-(--btn-regular-bg) object-cover transition group-hover:scale-105"
            />
            <div
              th:unless="${not #strings.isEmpty(link.spec.logo)}"
              class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-(--btn-regular-bg) text-(--primary)"
            >
              <span class="icon-[material-symbols--link-rounded] text-2xl"
              ></span>
            </div>
            <div class="min-w-0 flex-1">
              <div class="flex items-start gap-2">
                <div
                  class="min-w-0 flex-1 truncate text-base font-bold text-90 transition group-hover:text-(--primary)"
                  th:text="${link.spec.displayName}"
                >
                  Link
                </div>
                <span
                  class="icon-[fa6-solid--arrow-up-right-from-square] mt-0.5 shrink-0 text-sm text-30 transition group-hover:text-(--primary)"
                ></span>
              </div>
              <div
                th:if="${not #strings.isEmpty(link.spec.description)}"
                class="mt-1 line-clamp-2 text-sm leading-6 text-50"
                th:text="${link.spec.description}"
              >
                Description
              </div>
              <div
                class="mt-2 truncate text-xs font-medium text-30"
                th:text="${link.spec.url}"
              >
                https://example.com
              </div>
            </div>
          </a>
        </div>
      </section>
    </div>

    <div th:if="${#lists.isEmpty(groups)}" class="py-12 text-center text-50">
      暂无友情链接
    </div>
  </section>

  <!-- 折叠信息区域 -->
  <section
    th:if="${theme.config.links.enable_owner_info || theme.config.links.enable_requirements || theme.config.links.enable_disclaimer}"
    class="card-base onload-animation mb-4 px-6 py-6 md:px-9"
  >
    <h2 class="mb-4 text-xl font-bold text-90">
      <span>申请友链</span>
    </h2>

    <!-- 折叠面板容器 - 主题风格 -->
    <div class="space-y-2" id="links-accordion">
      <!-- 博客信息 -->
      <div
        th:if="${theme.config.links.enable_owner_info}"
        class="collapse-item rounded-xl bg-(--btn-regular-bg)"
      >
        <button
          type="button"
          class="collapse-header flex w-full items-center justify-between p-4 text-left transition"
          data-collapse-target="owner-info"
        >
          <div class="flex items-center gap-2">
            <span
              class="icon-[material-symbols--person-outline-rounded] text-xl text-(--primary)"
            ></span>
            <span class="font-medium text-90">我的博客信息</span>
          </div>
          <span
            class="collapse-icon icon-[material-symbols--expand-more-rounded] text-xl text-50 transition-transform duration-200"
            th:classappend="${theme.config.links.expand_owner_info} ? 'is-expanded'"
            data-expanded-class="is-expanded"></span>
        </button>
        <div
          id="owner-info"
          class="collapse-content"
          th:classappend="${theme.config.links.expand_owner_info} ? 'open'"
        >
          <div class="collapse-inner px-4 pb-4">
            <!-- 信息列表 -->
            <div class="space-y-0 text-sm">
              <!-- 名称 -->
              <div
                class="info-item flex items-center justify-between gap-2 rounded-lg bg-(--bg-secondary) py-1.5 px-2 pl-5"
              >
                <div class="flex items-center gap-2 min-w-0 flex-1">
                  <span class="text-90">名称：</span>
                  <span
                    class="text-50 truncate"
                    th:text="${theme.config.links.owner_name}">博客名称</span
                  >
                </div>
                <button
                  type="button"
                  class="copy-btn inline-flex items-center gap-1.5 rounded-lg bg-(--primary)/8 px-2 py-1 text-xs text-(--btn-content) transition hover:bg-(--primary)/15 hover:text-(--primary) active:scale-95"
                  th:attr="data-copy-text=${theme.config.links.owner_name}"
                  title="复制"
                >
                  <span
                    class="icon-[material-symbols--content-copy-outline-rounded] text-sm"
                  ></span>&#10; <span>复制</span>
                </button>
              </div>
              <!-- 描述 -->
              <div
                class="info-item flex items-center justify-between gap-2 rounded-lg bg-(--bg-secondary) py-1.5 px-2 pl-5"
              >
                <div class="flex items-center gap-2 min-w-0 flex-1">
                  <span class="text-90">描述：</span>
                  <span
                    class="truncate text-50"
                    th:text="${theme.config.links.owner_description}"
                    >博客描述</span
                  >
                </div>
                <button
                  type="button"
                  class="copy-btn inline-flex items-center gap-1.5 rounded-lg bg-(--primary)/8 px-2 py-1 text-xs text-(--btn-content) transition hover:bg-(--primary)/15 hover:text-(--primary) active:scale-95"
                  th:attr="data-copy-text=${theme.config.links.owner_description}"
                  title="复制"
                >
                  <span
                    class="icon-[material-symbols--content-copy-outline-rounded] text-sm"
                  ></span>&#10; <span>复制</span>
                </button>
              </div>
              <!-- 网址 -->
              <div
                class="info-item flex items-center justify-between gap-2 rounded-lg bg-(--bg-secondary) py-1.5 px-2 pl-5"
              >
                <div class="flex items-center gap-2 min-w-0 flex-1">
                  <span class="text-90">网址：</span>
                  <a
                    th:href="${theme.config.links.owner_url}"
                    class="truncate text-(--primary) hover:underline"
                    th:text="${theme.config.links.owner_url}"
                    >https://example.com</a
                  >
                </div>
                <button
                  type="button"
                  class="copy-btn inline-flex items-center gap-1.5 rounded-lg bg-(--primary)/8 px-2 py-1 text-xs text-(--btn-content) transition hover:bg-(--primary)/15 hover:text-(--primary) active:scale-95"
                  th:attr="data-copy-text=${theme.config.links.owner_url}"
                  title="复制"
                >
                  <span
                    class="icon-[material-symbols--content-copy-outline-rounded] text-sm"
                  ></span>&#10; <span>复制</span>
                </button>
              </div>
              <!-- 头像链接 -->
              <div
                class="info-item flex items-center justify-between gap-2 rounded-lg bg-(--bg-secondary) py-1.5 px-2 pl-5"
              >
                <div class="flex items-center gap-2 min-w-0 flex-1">
                  <span class="text-90">头像：</span>
                  <a
                    th:href="${theme.config.links.owner_avatar}"
                    class="truncate text-(--primary) hover:underline"
                    th:text="${theme.config.links.owner_avatar}"
                    >https://example.com/avatar.jpg</a
                  >
                </div>
                <button
                  type="button"
                  class="copy-btn inline-flex items-center gap-1.5 rounded-lg bg-(--primary)/8 px-2 py-1 text-xs text-(--btn-content) transition hover:bg-(--primary)/15 hover:text-(--primary) active:scale-95"
                  th:attr="data-copy-text=${theme.config.links.owner_avatar}"
                  title="复制"
                >
                  <span
                    class="icon-[material-symbols--content-copy-outline-rounded] text-sm"
                  ></span>&#10; <span>复制</span>
                </button>
              </div>
              <!-- RSS -->
              <div
                class="info-item flex items-center justify-between gap-2 rounded-lg bg-(--bg-secondary) py-1.5 px-2 pl-5"
              >
                <div class="flex items-center gap-2 min-w-0 flex-1">
                  <span class="text-90">RSS：</span>
                  <a
                    th:href="${theme.config.links.owner_rss}"
                    class="truncate text-(--primary) hover:underline"
                    th:text="${theme.config.links.owner_rss}">/rss.xml</a
                  >
                </div>
                <button
                  type="button"
                  class="copy-btn inline-flex items-center gap-1.5 rounded-lg bg-(--primary)/8 px-2 py-1 text-xs text-(--btn-content) transition hover:bg-(--primary)/15 hover:text-(--primary) active:scale-95"
                  th:attr="data-copy-text=${theme.config.links.owner_rss}"
                  title="复制"
                >
                  <span
                    class="icon-[material-symbols--content-copy-outline-rounded] text-sm"
                  ></span>&#10; <span>复制</span>
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- 友链须知 -->
      <div
        th:if="${theme.config.links.enable_requirements && not #strings.isEmpty(theme.config.links.requirements)}"
        class="collapse-item rounded-xl bg-(--btn-regular-bg)"
      >
        <button
          type="button"
          class="collapse-header flex w-full items-center justify-between p-4 text-left transition"
          data-collapse-target="requirements"
        >
          <div class="flex items-center gap-2">
            <span
              class="icon-[material-symbols--checklist-rounded] text-xl text-(--primary)"
            ></span>
            <span class="font-medium text-90">友链须知</span>
          </div>
          <span
            class="collapse-icon icon-[material-symbols--expand-more-rounded] text-xl text-50 transition-transform duration-200"
          ></span>
        </button>
        <div id="requirements" class="collapse-content">
          <div class="collapse-inner px-4 pb-4">
            <ul
              th:if="${not #strings.isEmpty(theme.config.links.requirements)}"
              class="requirements-list list-outside list-disc space-y-1 text-sm text-50 pl-5"
              th:data-text="${theme.config.links.requirements}"
            >
            </ul>
          </div>
        </div>
      </div>

      <!-- 免责申明 -->
      <div
        th:if="${theme.config.links.enable_disclaimer && not #strings.isEmpty(theme.config.links.disclaimer)}"
        class="collapse-item rounded-xl bg-(--btn-regular-bg)"
      >
        <button
          type="button"
          class="collapse-header flex w-full items-center justify-between p-4 text-left transition"
          data-collapse-target="disclaimer"
        >
          <div class="flex items-center gap-2">
            <span
              class="icon-[material-symbols--warning-outline-rounded] text-xl text-(--primary)"
            ></span>
            <span class="font-medium text-90">免责申明</span>
          </div>
          <span
            class="collapse-icon icon-[material-symbols--expand-more-rounded] text-xl text-50 transition-transform duration-200"
          ></span>
        </button>
        <div id="disclaimer" class="collapse-content">
          <div class="collapse-inner px-4 pb-4">
            <ul
              class="disclaimer-list list-outside list-disc space-y-1 text-sm text-50 pl-5"
              th:data-text="${theme.config.links.disclaimer}"
            >
            </ul>
          </div>
        </div>
      </div>

      <!-- 友链提交表单 - 折叠面板形式 -->
      <div
        th:if="${pluginFinder.available('link-submit') && theme.config.links.enable_apply_btn}"
        class="collapse-item rounded-xl bg-(--btn-regular-bg)"
      >
        <!-- 折叠头部 - 申请友链按钮 -->
        <button
          type="button"
          class="collapse-header flex w-full items-center justify-between p-4 text-left transition"
          data-collapse-target="link-submit-form"
        >
          <div class="flex items-center gap-2">
            <span
              class="icon-[material-symbols--add-circle-outline-rounded] text-xl text-(--primary)"
            ></span>
            <span class="font-medium text-90">申请友链</span>
          </div>
          <span
            class="collapse-icon icon-[material-symbols--expand-more-rounded] text-xl text-50 transition-transform duration-200"
          ></span>
        </button>

        <!-- 折叠内容 - 表单 -->
        <div id="link-submit-form" class="collapse-content">
          <div class="collapse-inner px-4 pb-4">
            <!-- 成功提示 -->
            <div
              id="link-submit-success"
              class="hidden text-center py-6 mb-4 bg-(--bg-secondary) rounded-lg"
            >
              <span
                class="icon-[material-symbols--check-circle-rounded] text-5xl text-green-500 mb-3 block mx-auto"
              ></span>
              <h3 class="text-base font-bold text-90 mb-1">提交成功！</h3>
              <p class="text-sm text-50">
                您的友链申请已提交，管理员审核通过后即可显示。
              </p>
            </div>

            <!-- 表单 -->
            <form id="link-submit-form-actual" class="space-y-3">
              <!-- 类型选择 -->
              <div>
                <label class="mb-1.5 block text-sm font-medium text-90"
                  >申请类型</label
                >
                <div class="flex gap-2">
                  <label
                    class="link-type-label flex flex-1 cursor-pointer items-center justify-center gap-1.5 rounded-lg bg-(--primary) px-3 py-2 text-xs font-bold text-white transition hover:opacity-90"
                  >
                    <input
                      type="radio"
                      name="type"
                      value="add"
                      checked
                      class="sr-only"
                    />
                    <span
                      class="link-type-icon icon-[material-symbols--add-circle-outline-rounded]"
                    ></span>
                    <span class="link-type-text">新增友链</span>
                  </label>
                  <label
                    class="link-type-label flex flex-1 cursor-pointer items-center justify-center gap-1.5 rounded-lg bg-(--btn-regular-bg) px-3 py-2 text-xs font-medium text-(--btn-content) transition"
                  >
                    <input
                      type="radio"
                      name="type"
                      value="update"
                      class="sr-only"
                    />
                    <span
                      class="link-type-icon icon-[material-symbols--edit-rounded]"
                    ></span>
                    <span class="link-type-text">更新友链</span>
                  </label>
                </div>
              </div>

              <!-- 网站名称 + 网站地址 -->
              <div class="grid grid-cols-2 gap-3">
                <div>
                  <label
                    for="displayName"
                    class="mb-1 block text-sm font-medium text-90"
                  >
                    网站名称 <span class="text-red-500">*</span>
                  </label>
                  <input
                    type="text"
                    id="displayName"
                    name="displayName"
                    required
                    placeholder="网站名称"
                    class="w-full rounded-lg border-2 bg-transparent px-3 py-2 text-sm text-90 placeholder:text-black/25 dark:placeholder:text-white/20 focus:outline-none transition"
                  />
                </div>
                <div>
                  <label
                    for="url"
                    class="mb-1 block text-sm font-medium text-90"
                  >
                    网站地址 <span class="text-red-500">*</span>
                  </label>
                  <input
                    type="url"
                    id="url"
                    name="url"
                    required
                    placeholder="https://"
                    class="w-full rounded-lg border-2 bg-transparent px-3 py-2 text-sm text-90 placeholder:text-black/25 dark:placeholder:text-white/20 focus:outline-none transition"
                  />
                </div>
              </div>

              <!-- 网站Logo + 邮箱 -->
              <div class="grid grid-cols-2 gap-3">
                <div>
                  <label
                    for="logo"
                    class="mb-1 block text-sm font-medium text-90"
                    >网站Logo</label
                  >
                  <input
                    type="url"
                    id="logo"
                    name="logo"
                    placeholder="图片链接"
                    class="w-full rounded-lg border-2 bg-transparent px-3 py-2 text-sm text-90 placeholder:text-black/25 dark:placeholder:text-white/20 focus:outline-none transition"
                  />
                </div>
                <div>
                  <label
                    for="email"
                    class="mb-1 block text-sm font-medium text-90">邮箱</label
                  >
                  <input
                    type="email"
                    id="email"
                    name="email"
                    placeholder="用于通知"
                    class="w-full rounded-lg border-2 bg-transparent px-3 py-2 text-sm text-90 placeholder:text-black/25 dark:placeholder:text-white/20 focus:outline-none transition"
                  />
                </div>
              </div>

              <!-- 分组 + 网站描述 -->
              <div class="grid grid-cols-2 gap-3">
                <div>
                  <label
                    for="groupName"
                    class="mb-1 block text-sm font-medium text-90">分组</label
                  >
                  <select
                    id="groupName"
                    name="groupName"
                    class="w-full h-10 rounded-lg border-2 bg-transparent px-3 py-2 text-sm text-90 focus:outline-none transition"
                  >
                    <option value="">默认分组</option>
                  </select>
                </div>
                <div>
                  <label
                    for="description"
                    class="mb-1 block text-sm font-medium text-90"
                    >网站描述</label
                  >
                  <textarea
                    id="description"
                    name="description"
                    rows="2"
                    placeholder="简单介绍一下您的网站"
                    class="w-full resize-none rounded-lg border-2 bg-transparent px-3 py-2 text-sm text-90 placeholder:text-black/25 dark:placeholder:text-white/20 focus:outline-none transition"
                  ></textarea>
                </div>
              </div>

              <!-- RSS订阅 + 验证码 -->
              <div class="grid grid-cols-2 gap-3">
                <div>
                  <label
                    for="rssUrl"
                    class="mb-1 block text-sm font-medium text-90"
                    >RSS订阅</label
                  >
                  <input
                    type="url"
                    id="rssUrl"
                    name="rssUrl"
                    placeholder="RSS链接"
                    class="w-full rounded-lg border-2 bg-transparent px-3 py-2 text-sm text-90 placeholder:text-black/25 dark:placeholder:text-white/20 focus:outline-none transition"
                  />
                </div>
                <div>
                  <label class="mb-1 block text-sm font-medium text-90"
                    >验证码</label
                  >
                  <div class="flex gap-2">
                    <canvas
                      id="link-captcha-canvas"
                      width="100"
                      height="36"
                      class="h-9 w-20 flex-shrink-0 cursor-pointer rounded-md border-2"
                      title="点击刷新验证码"></canvas>
                    <input
                      type="text"
                      id="link-captcha-input"
                      maxlength="4"
                      autocomplete="off"
                      placeholder="验证码"
                      class="w-full rounded-md border-2 bg-transparent px-2 py-1.5 text-sm text-90 outline-none transition"
                    />
                  </div>
                </div>
              </div>

              <!-- 更新描述 -->
              <div id="update-description-wrapper" class="hidden">
                <label
                  for="updateDescription"
                  class="mb-1 block text-sm font-medium text-90">更新说明</label
                >
                <textarea
                  id="updateDescription"
                  name="updateDescription"
                  rows="2"
                  placeholder="请说明本次更新的内容"
                  class="w-full resize-none rounded-lg border-2 bg-transparent px-3 py-2 text-sm text-90 placeholder:text-black/25 dark:placeholder:text-white/20 focus:outline-none transition"
                ></textarea>
              </div>

              <!-- 提交按钮 -->
              <div class="pt-1 flex justify-center">
                <button
                  type="submit"
                  id="submit-link-btn"
                  class="inline-flex items-center justify-center rounded-lg bg-(--primary) px-8 py-2.5 text-sm font-bold text-white active:scale-[0.98] transition hover:opacity-90"
                >
                  <span id="submit-btn-text">提交申请</span>
                  <span
                    id="submit-btn-loading"
                    class="hidden items-center justify-center"
                  >
                    <svg
                      class="animate-spin mr-2 h-4 w-4"
                      xmlns="http://www.w3.org/2000/svg"
                      fill="none"
                      viewBox="0 0 24 24"
                    >
                      <circle
                        class="opacity-25"
                        cx="12"
                        cy="12"
                        r="10"
                        stroke="currentColor"
                        stroke-width="4"></circle>
                      <path
                        class="opacity-75"
                        fill="currentColor"
                        d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
                      ></path>
                    </svg>
                    提交中...
                  </span>
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
    <!-- 友链提交表单脚本 -->
    <script is:inline>
      (function () {
        // ====== 验证码 ======
        var captchaCode = "";
        function drawCaptcha() {
          var canvas = document.getElementById("link-captcha-canvas");
          if (!canvas) return;
          var ctx = canvas.getContext("2d");
          var chars = "ABCDEFGHJKLMNPQRSTUVWXYZ23456789";
          captchaCode = "";
          for (var i = 0; i < 4; i++)
            captchaCode += chars[Math.floor(Math.random() * chars.length)];
          ctx.clearRect(0, 0, canvas.width, canvas.height);
          ctx.fillStyle =
            getComputedStyle(document.documentElement)
              .getPropertyValue("--card-bg")
              .trim() || "#fff";
          ctx.fillRect(0, 0, canvas.width, canvas.height);
          for (var i = 0; i < 4; i++) {
            ctx.font = 'bold 20px "Courier New", monospace';
            ctx.fillStyle =
              "#" +
              Math.floor(Math.random() * 0x888888 + 0x444444).toString(16);
            ctx.save();
            ctx.translate(18 + i * 20, 24);
            ctx.rotate((Math.random() - 0.5) * 0.4);
            ctx.fillText(captchaCode[i], -8, 6);
            ctx.restore();
          }
          // 干扰线
          for (var i = 0; i < 3; i++) {
            ctx.strokeStyle = "rgba(0,0,0,0.1)";
            ctx.beginPath();
            ctx.moveTo(Math.random() * 100, Math.random() * 36);
            ctx.lineTo(Math.random() * 100, Math.random() * 36);
            ctx.stroke();
          }
        }
        var captchaCanvas = document.getElementById("link-captcha-canvas");
        if (captchaCanvas) {
          drawCaptcha();
          captchaCanvas.addEventListener("click", drawCaptcha);
        }

        // 获取分组列表
        async function fetchGroups() {
          try {
            const response = await fetch(
              "/apis/anonymous.link.submit.kunkunyu.com/v1alpha1/linkgroups",
            );
            if (response.ok) {
              const data = await response.json();
              const select = document.getElementById("groupName");

              // 处理不同的返回格式
              let groups = [];
              if (Array.isArray(data)) {
                groups = data;
              } else if (data.items) {
                groups = data.items;
              } else if (data.spec) {
                groups = [data];
              }

              if (select && groups.length > 0) {
                // 移除默认选项
                var defaultOption = select.querySelector('option[value=""]');
                if (defaultOption) defaultOption.remove();

                groups.forEach(function (item) {
                  var option = document.createElement("option");
                  var name =
                    item.groupName || item.metadata?.name || item.name || "";
                  var label =
                    item.displayName ||
                    item.spec?.displayName ||
                    item.name ||
                    "";
                  option.value = name;
                  option.textContent = label;
                  if (option.value) {
                    select.appendChild(option);
                  }
                });
              }
            }
          } catch (e) {
            // 获取分组失败，静默使用默认分组
          }
        }

        // 绑定事件
        function initLinkSubmit() {
          var form = document.getElementById("link-submit-form-actual");
          var typeRadios = document.querySelectorAll('input[name="type"]');
          var updateWrapper = document.getElementById(
            "update-description-wrapper",
          );

          // 更新类型选择按钮样式 - CSS :has() 处理颜色，JS 用来清除 inline style
          function updateTypeStyles() {
            var typeLabels = form.querySelectorAll(".link-type-label");
            var primaryColor = getComputedStyle(document.documentElement)
              .getPropertyValue("--primary")
              .trim();
            typeLabels.forEach(function (label) {
              var input = label.querySelector("input");
              if (input && input.checked) {
                // 选中状态
                label.style.backgroundColor = primaryColor;
                label.style.color = "#ffffff";
                label.style.fontWeight = "bold";
                label.style.borderColor = primaryColor;
              } else {
                // 未选中状态 - 清除 inline style，让 CSS :not(:has(input:checked)) 规则生效
                label.style.backgroundColor = "";
                label.style.color = "";
                label.style.fontWeight = "";
                label.style.borderColor = "";
              }
            });
          }

          // 类型切换
          typeRadios.forEach(function (radio) {
            radio.addEventListener("change", function () {
              if (updateWrapper) {
                updateWrapper.classList.toggle(
                  "hidden",
                  this.value !== "update",
                );
              }
              updateTypeStyles();
            });
          });

          // 初始化类型样式
          updateTypeStyles();

          // 表单提交
          if (form) {
            form.addEventListener("submit", async function (e) {
              e.preventDefault();

              // 验证码校验
              var captchaInput = document.getElementById("link-captcha-input");
              if (
                captchaInput &&
                captchaInput.value.toUpperCase() !== captchaCode
              ) {
                alert("验证码错误，请重新输入");
                captchaInput.value = "";
                drawCaptcha();
                return;
              }

              var submitBtn = document.getElementById("submit-link-btn");
              var btnText = document.getElementById("submit-btn-text");
              var btnLoading = document.getElementById("submit-btn-loading");
              var successDiv = document.getElementById("link-submit-success");

              // 显示加载状态
              submitBtn.disabled = true;
              btnText.classList.add("hidden");
              btnLoading.classList.remove("hidden");

              var formData = new FormData(form);
              var data = {
                type: formData.get("type"),
                displayName: formData.get("displayName"),
                url: formData.get("url"),
              };

              // 添加可选字段
              if (formData.get("logo")) data.logo = formData.get("logo");
              if (formData.get("email")) data.email = formData.get("email");
              if (formData.get("description"))
                data.description = formData.get("description");
              if (formData.get("groupName"))
                data.groupName = formData.get("groupName");
              if (formData.get("rssUrl")) data.rssUrl = formData.get("rssUrl");
              if (formData.get("updateDescription"))
                data.updateDescription = formData.get("updateDescription");

              try {
                var response = await fetch(
                  "/apis/anonymous.link.submit.kunkunyu.com/v1alpha1/linksubmits/-/submit",
                  {
                    method: "POST",
                    headers: {
                      "Content-Type": "application/json",
                    },
                    body: JSON.stringify(data),
                  },
                );

                if (response.ok) {
                  // 成功 - 显示成功提示，隐藏表单
                  form.classList.add("hidden");
                  if (successDiv) {
                    successDiv.classList.remove("hidden");
                  }
                } else {
                  var errorData = await response.json().catch(function () {
                    return {};
                  });
                  alert(
                    "提交失败：" +
                      (errorData.message || "请检查输入信息是否正确"),
                  );
                }
              } catch (err) {
                alert("提交失败：网络错误，请稍后重试");
              } finally {
                submitBtn.disabled = false;
                btnText.classList.remove("hidden");
                btnLoading.classList.add("hidden");
              }
            });
          }
        }

        // 初始化
        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", function () {
            initLinkSubmit();
            fetchGroups();
          });
        } else {
          initLinkSubmit();
          fetchGroups();
        }

        // Swup 页面切换后重新初始化
        document.addEventListener("swup:contentReplaced", function () {
          setTimeout(function () {
            initLinkSubmit();
            fetchGroups();
            // 重新生成验证码
            drawCaptcha();
            var c = document.getElementById("link-captcha-canvas");
            if (c) c.addEventListener("click", drawCaptcha);
          }, 100);
        });
      })();
    </script>
  </section>

  <!-- 评论区 -->
  <div
    id="comment"
    th:if="${haloCommentEnabled && (theme.config.links.enable_comment == null || theme.config.links.enable_comment)}"
    class="card-base relative z-10 w-full px-6 pb-4 pt-6 md:px-9"
  >
    <h2
      class="mb-2 text-base font-medium text-gray-900 dark:text-slate-50"
      th:text="#{common.comment}"
    >
      评论
    </h2>
    <Fragment
      set:html={'<halo:comment group="plugin.halo.run" kind="Plugin" th:attr="name=${pluginName}" />'}
    />
  </div>
</MainGridLayout>
