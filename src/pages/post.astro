---
import PostMeta from "../components/PostMeta.astro";
import MainGridLayout from "../layouts/MainGridLayout.astro";
---

<MainGridLayout
  title="${post.spec.title + ' - ' + site.title}"
  setOGTypeArticle={true}
  showToc={true}
>
  <Fragment slot="head">
    <title th:text="${post.spec.title + ' - ' + site.title}"></title>
    <meta property="og:title" th:content="${post.spec.title}" />
    <meta property="og:description" th:content="${post.status.excerpt}" />
    <meta
      property="og:image"
      th:if="${not #strings.isEmpty(post.spec.cover)}"
      th:content="${post.spec.cover}"
    />
  </Fragment>

  <article
    class="relative mb-4 flex w-full overflow-hidden rounded-(--radius-large)"
  >
    <div
      id="post-container"
      class="card-base relative z-10 w-full px-6 pb-4 pt-6 md:px-9"
    >
      <div
        class="onload-animation mb-3 flex flex-row gap-5 text-black/30 transition dark:text-white/30"
        th:if="${post.stats != null}"
      >
        <div class="flex flex-row items-center">
          <div
            class="mr-2 flex h-6 w-6 items-center justify-center rounded-md bg-black/5 text-black/50 transition dark:bg-white/10 dark:text-white/50"
          >
            <span class="icon-[material-symbols--visibility-outline-rounded]"
            ></span>
          </div>
          <span class="text-sm" th:text="${post.stats.visit}">0</span>
        </div>
        <div class="flex flex-row items-center">
          <div
            class="mr-2 flex h-6 w-6 items-center justify-center rounded-md bg-black/5 text-black/50 transition dark:bg-white/10 dark:text-white/50"
          >
            <span class="icon-[material-symbols--chat-bubble-outline-rounded]"
            ></span>
          </div>
          <span class="text-sm" th:text="${post.stats.comment}">0</span>
        </div>
      </div>

      <div class="onload-animation relative">
        <h1
          class="mb-3 block w-full text-3xl font-bold text-black/90 transition before:absolute before:-left-4.5 before:top-3 before:h-5 before:rounded-md before:bg-(--primary) dark:text-white/90 md:text-[2.25rem]/[2.75rem] md:before:w-1"
          th:text="${post.spec.title}"
        >
          Post title
        </h1>
      </div>

      <div class="onload-animation">
        <PostMeta class="mb-5" />
        <div
          th:if="${not #strings.isEmpty(post.spec.cover)}"
          id="post-cover"
          class="mb-5 overflow-hidden rounded-xl"
        >
          <img
            alt=""
            th:src="${post.spec.cover}"
            th:alt="${post.spec.title}"
            class="max-h-112 w-full object-cover"
          />
        </div>
      </div>

      <div
        id="content"
        class="custom-md markdown-content onload-animation prose prose-base mb-6 max-w-none! dark:prose-invert!"
        th:classappend="| ${theme.config.post.contentDisplay.content_size} ${theme.config.post.contentDisplay.content_theme}|"
        th:utext="${post.content.content}"
      >
      </div>

      <div
        th:if="${theme.config.post.license.enable}"
        class="license-container onload-animation relative mb-6 overflow-hidden rounded-xl bg-(--license-block-bg) px-6 py-5 transition"
      >
        <div
          class="font-bold text-black/75 transition dark:text-white/75"
          th:text="${post.spec.title}"
        >
          Post title
        </div>
        <a
          data-current-post-url
          th:href="@{${post.status.permalink}}"
          th:text="${post.status.permalink}"
          href="#"
          class="link break-all text-(--primary)">https://example.com/post</a
        >
        <div class="mt-2 flex flex-wrap gap-6">
          <div>
            <div
              class="text-sm text-black/30 transition dark:text-white/30"
              th:text="#{common.author}"
            >
              作者
            </div>
            <div
              class="line-clamp-2 text-black/75 transition dark:text-white/75"
              th:text="${post.owner.displayName}"
            >
            </div>
          </div>
          <div>
            <div
              class="text-sm text-black/30 transition dark:text-white/30"
              th:text="#{common.publishedAt}"
            >
              发布于
            </div>
            <div
              class="line-clamp-2 text-black/75 transition dark:text-white/75"
              th:text="${#dates.format(post.spec.publishTime,'yyyy-MM-dd')}"
            >
            </div>
          </div>
          <div>
            <div
              class="text-sm text-black/30 transition dark:text-white/30"
              th:text="#{common.license}"
            >
              License
            </div>
            <a
              th:href="${theme.config.post.license.url}"
              target="_blank"
              class="link line-clamp-2 text-(--primary)"
              th:text="${theme.config.post.license.name}">CC BY-NC-SA 4.0</a
            >
          </div>
        </div>
        <span
          class="icon-[fa6-brands--creative-commons] pointer-events-none absolute right-6 top-1/2 -translate-y-1/2 text-[15rem] text-black/5 transition dark:text-white/5"
        ></span>
      </div>
      <!-- 点赞按钮 -->
      <div
        th:if="${theme.config.post.enable_like != false}"
        class="onload-animation mb-6 flex justify-center"
      >
        <button
          id="post-like-btn"
          class="group relative flex cursor-pointer items-center gap-2 rounded-2xl border border-(--line-color) px-5 py-2.5 transition hover:border-(--primary)/30 hover:bg-(--btn-card-bg-hover) active:scale-[0.97]"
          th:attr="data-post=${post.metadata.name}"
          th:data-count="${post.stats.upvote}"
          aria-label="点赞"
        >
          <span
            id="post-like-icon"
            class="icon-[material-symbols--favorite-outline-rounded] text-2xl text-red-400 transition group-[.liked]:icon-[material-symbols--favorite-rounded] group-[.liked]:text-red-500 group-[.liked]:scale-110"
          ></span>
          <span
            id="post-like-count"
            class="text-sm font-medium text-50 transition group-[.liked]:text-red-500"
            th:text="${post.stats.upvote > 0 ? post.stats.upvote : ''}"></span>
        </button>
      </div>
    </div>
  </article>

  <nav
    class="mb-4 flex w-full flex-col justify-between gap-4 overflow-hidden md:flex-row"
    th:with="postCursor = ${postFinder.cursor(post.metadata.name)}"
    aria-label="Post navigation"
  >
    <a
      th:if="${postCursor.hasPrevious()}"
      class="w-full overflow-hidden font-bold active:scale-95"
      th:href="@{${postCursor.previous.status.permalink}}"
      th:title="${postCursor.previous.spec.title}"
    >
      <div
        class="btn-card flex h-15 w-full max-w-full justify-start! gap-4 rounded-2xl px-4"
      >
        <span
          class="icon-[material-symbols--chevron-left-rounded] text-2xl! font-black text-(--primary)"
        ></span>
        <span
          class="max-w-[calc(100%-3rem)] overflow-hidden overflow-ellipsis whitespace-nowrap text-black/75 transition dark:text-white/75"
          th:text="${postCursor.previous.spec.title}"></span>
      </div>
    </a>
    <div
      th:unless="${postCursor.hasPrevious()}"
      class="btn-card h-15 w-full rounded-2xl px-4 text-30"
    >
      <span th:text="#{common.noOlderPost}">没有更早的文章</span>
    </div>
    <a
      th:if="${postCursor.hasNext()}"
      class="w-full overflow-hidden font-bold active:scale-95"
      th:href="@{${postCursor.next.status.permalink}}"
      th:title="${postCursor.next.spec.title}"
    >
      <div
        class="btn-card flex h-15 w-full max-w-full justify-end! gap-4 rounded-2xl px-4"
      >
        <span
          class="max-w-[calc(100%-3rem)] overflow-hidden overflow-ellipsis whitespace-nowrap text-black/75 transition dark:text-white/75"
          th:text="${postCursor.next.spec.title}"></span>
        <span
          class="icon-[material-symbols--chevron-right-rounded] text-2xl! font-black text-(--primary)"
        ></span>
      </div>
    </a>
    <div
      th:unless="${postCursor.hasNext()}"
      class="btn-card h-15 w-full rounded-2xl px-4 text-30"
    >
      <span th:text="#{common.noNewerPost}">没有更新的文章</span>
    </div>
  </nav>

  <div
    class="card-base relative z-10 w-full px-6 pb-4 pt-6 md:px-9"
    id="comment"
    th:if="${haloCommentEnabled}"
  >
    <h2
      class="mb-2 text-base font-medium text-gray-900 dark:text-slate-50"
      th:text="#{common.comment}"
    >
      评论
    </h2>
    <Fragment
      set:html={'<halo:comment group="content.halo.run" kind="Post" th:attr="name=${post.metadata.name}" />'}
    />
  </div>

  <script is:inline>
    window.__fuwariSyncCurrentPostUrl = function () {
      let currentUrl = window.location.href;
      try {
        currentUrl = decodeURIComponent(currentUrl);
      } catch {}
      document.querySelectorAll("[data-current-post-url]").forEach((link) => {
        link.setAttribute("href", currentUrl);
        link.textContent = currentUrl;
      });
    };

    window.__fuwariSyncCurrentPostUrl();
    if (!window.__fuwariSyncCurrentPostUrlBound) {
      window.__fuwariSyncCurrentPostUrlBound = true;
      document.addEventListener("astro:page-load", () =>
        window.__fuwariSyncCurrentPostUrl?.(),
      );
      document.addEventListener("swup:contentReplaced", () =>
        window.__fuwariSyncCurrentPostUrl?.(),
      );
    }
  </script>

  <!-- 点赞按钮（Halo API 服务端存储） -->
  <script is:inline>
    (function () {
      var btn = document.getElementById("post-like-btn");
      if (!btn) return;
      var postName = btn.getAttribute("data-post");
      var svCount = parseInt(btn.getAttribute("data-count") || "0", 10);
      var key = "fuwari-like-" + postName;
      var liked = localStorage.getItem(key) === "1";
      var countEl = document.getElementById("post-like-count");
      var count = Math.max(
        svCount,
        parseInt(localStorage.getItem(key + "-count") || "0", 10) || 0,
      );

      if (liked) btn.classList.add("liked");
      if (countEl) countEl.textContent = count > 0 ? count : "";

      btn.addEventListener("click", function () {
        if (btn.classList.contains("liked")) return;
        btn.classList.add("liked");
        localStorage.setItem(key, "1");
        count++;
        localStorage.setItem(key + "-count", count);
        if (countEl) countEl.textContent = count;
        // 调用 Halo upvote API
        fetch("/apis/api.halo.run/v1alpha1/trackers/upvote", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            group: "content.halo.run",
            plural: "posts",
            name: postName,
          }),
        }).catch(function () {});
      });
    })();
  </script>
</MainGridLayout>
