---
import Pagination from "../components/control/Pagination.astro";
import MainGridLayout from "../layouts/MainGridLayout.astro";
---

<MainGridLayout title="${title + ' - ' + site.title}">
  <Fragment slot="head">
    <title th:text="${title + ' - ' + site.title}"></title>
  </Fragment>

  <!-- 朋友圈头部 -->
  <section class="card-base onload-animation mb-4 overflow-hidden px-5 py-5 md:px-7 md:py-6">
    <div class="mb-5 flex flex-col items-start gap-3 md:flex-row md:items-end md:justify-between">
      <div>
        <h1 class="text-3xl font-bold text-90" th:text="${title}">朋友圈</h1>
        <div class="mt-1 text-sm text-50">
          <span th:text="#{page.friends.description}">关注博主的最新动态</span>
        </div>
      </div>
    </div>

    <!-- 使用 /friends 路由提供的 friends 变量 -->
    <div th:if="${not #lists.isEmpty(friends.items)}" class="friends-list grid gap-4 sm:grid-cols-2 onload-animation">
      <article th:each="friend : ${friends.items}" class="btn-card items-start! justify-start! min-h-24 rounded-xl p-4">
        <div class="flex items-start gap-3">
          <!-- 头像 -->
          <div class="relative shrink-0">
            <img
              th:if="${not #strings.isEmpty(friend.spec.logo)}"
              th:src="${friend.spec.logo}"
              th:alt="${friend.spec.author}"
              class="h-10 w-10 rounded-full object-cover ring-2 ring-(--btn-card-bg-hover)"
            />
            <div
              th:unless="${not #strings.isEmpty(friend.spec.logo)}"
              class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-(--card-bg) text-(--primary) ring-2 ring-(--btn-card-bg-hover)"
            >
              <span class="icon-[material-symbols--account-circle] text-2xl"></span>
            </div>
          </div>

          <div class="min-w-0 flex-1">
            <!-- 作者信息和时间 -->
            <div class="flex items-start justify-between gap-2">
              <div class="min-w-0">
                <a
                  href="#"
                  class="friend-author block truncate text-sm font-bold text-(--primary) hover:underline"
                  th:attr="data-site=${friend.spec.postLink}"
                >
                  <span th:text="${friend.spec.author}"></span>
                </a>
                <time
                  class="mt-0.5 block text-xs text-50"
                  th:datetime="${friend.spec.pubDate}"
                  th:text="${friend.spec.pubDate != null ? #dates.format(friend.spec.pubDate, 'yyyy-MM-dd') : ''}"
                ></time>
              </div>
            </div>

            <!-- 文章标题（唯一可点击跳转） -->
            <a
              th:href="${friend.spec.postLink}"
              target="_blank"
              rel="noopener noreferrer"
              class="mt-2 block line-clamp-2 text-sm font-medium text-90 transition hover:text-(--primary) hover:underline"
            >
              <span th:text="${friend.spec.title}">Title</span>
              <span class="icon-[fa6-solid--arrow-up-right-from-square] ml-0.5 inline-block text-xs text-30 align-middle"></span>
            </a>

            <!-- 文章描述 -->
            <div
              th:if="${not #strings.isEmpty(friend.spec.description)}"
              class="mt-1.5 line-clamp-2 text-xs text-50"
              th:text="${friend.spec.description}"
            ></div>

            <!-- 来源标识 -->
            <div class="mt-2 flex items-center gap-1 text-[0.65rem] text-30">
              <span class="icon-[material-symbols--link-rounded] text-xs"></span>
              <span th:text="#{page.friends.source}">来自朋友圈</span>
            </div>
          </div>
        </div>
      </article>
    </div>

    <!-- 空状态 -->
    <div th:if="${#lists.isEmpty(friends.items)}" class="py-12 text-center text-50">
      <span class="icon-[material-symbols--inbox-rounded] text-5xl text-30"></span>
      <p class="mt-4" th:text="#{page.friends.empty}">暂无朋友圈动态</p>
    </div>

    <!-- 分页 -->
    <Pagination context="friends" class="mb-4 onload-animation" />
  </section>

  <!-- 从文章链接提取博客主页，给博客名添加跳转 -->
  <script is:inline>
    document.querySelectorAll('.friend-author').forEach(function(a) {
      var postLink = a.getAttribute('data-site');
      if (!postLink) return;
      try {
        var u = new URL(postLink);
        a.href = u.origin + '/';
      } catch(e) {
        // 如果 postLink 格式错误，使用原文链接
        a.href = postLink;
      }
      a.target = '_blank';
      a.rel = 'noopener noreferrer';
    });
  </script>

</MainGridLayout>
