---
import MainGridLayout from "../layouts/MainGridLayout.astro";
---

<MainGridLayout title="${singlePage.spec.title + ' - ' + site.title}">
  <Fragment slot="head">
    <title th:text="${singlePage.spec.title + ' - ' + site.title}"></title>
  </Fragment>

  <section class="card-base onload-animation mb-4 px-5 py-5 md:px-7 md:py-6">
    <div
      class="mb-5 flex flex-col items-start gap-3 md:flex-row md:items-end md:justify-between"
    >
      <div>
        <h1
          class="text-3xl font-bold text-90"
          th:text="${singlePage.spec.title}"
        >
          朋友圈
        </h1>
        <div class="mt-1 text-sm text-50">
          <span th:text="#{page.friends.description}">关注博主的最新动态</span>
        </div>
      </div>
    </div>

    <th:block th:with="feedPage = ${linkFeedFinder.list({})}">
      <div
        th:if="${not #lists.isEmpty(feedPage.items)}"
        class="friends-list grid gap-4 sm:grid-cols-2 onload-animation"
      >
        <article
          th:each="item : ${feedPage.items}"
          class="btn-card btn-card-outline card-tilt group items-start! justify-start! min-h-24 rounded-xl p-4"
        >
          <div class="flex items-start gap-3">
            <div class="relative shrink-0">
              <img
                th:if="${not #strings.isEmpty(item.authorLogo)}"
                th:src="${item.authorLogo}"
                th:alt="${item.author}"
                class="h-10 w-10 rounded-xl bg-(--btn-regular-bg) object-cover transition group-hover:scale-105"
              />
              <div
                th:unless="${not #strings.isEmpty(item.authorLogo)}"
                class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-(--btn-regular-bg) text-(--primary)"
              >
                <span class="icon-[material-symbols--account-circle] text-2xl"
                ></span>
              </div>
            </div>

            <div class="min-w-0 flex-1">
              <div class="flex items-start justify-between gap-2">
                <div class="min-w-0">
                  <a
                    href="#"
                    class="friend-author block truncate text-sm font-bold text-(--primary) hover:underline"
                    th:attr="data-site=${item.url}"
                  >
                    <span th:text="${item.author}"></span>
                  </a>
                  <time
                    class="mt-0.5 block text-xs text-50"
                    th:datetime="${item.publishedAt}"
                    th:text="${item.publishedAt != null ? #dates.format(item.publishedAt, 'yyyy-MM-dd') : ''}"
                  ></time>
                </div>
              </div>

              <a
                th:href="${item.url}"
                target="_blank"
                rel="noopener noreferrer"
                class="mt-2 block line-clamp-2 text-sm font-medium text-90 transition hover:text-(--primary) hover:underline"
              >
                <span th:text="${item.title}">Title</span>
                <span
                  class="icon-[fa6-solid--arrow-up-right-from-square] ml-0.5 inline-block text-xs text-30 align-middle"
                ></span>
              </a>

              <div
                th:if="${not #strings.isEmpty(item.summary)}"
                class="mt-1.5 line-clamp-2 text-xs text-50"
                th:text="${item.summary}"
              >
              </div>

              <div class="mt-2 flex items-center gap-1 text-[0.65rem] text-30">
                <span class="icon-[material-symbols--link-rounded] text-xs"
                ></span>
                <span th:text="#{page.friends.source}">来自朋友圈</span>
              </div>
            </div>
          </div>
        </article>
      </div>

      <div
        th:if="${#lists.isEmpty(feedPage.items)}"
        class="py-12 text-center text-50"
      >
        <span class="icon-[material-symbols--inbox-rounded] text-5xl text-30"
        ></span>
        <p class="mt-4" th:text="#{page.friends.empty}">暂无朋友圈动态</p>
      </div>

      <nav
        th:if="${feedPage.hasNext}"
        class="mt-6 flex flex-row justify-center gap-3"
      >
        <a
          th:href="@{?beforePublishedAt=${feedPage.nextBeforePublishedAt}&beforeId=${feedPage.nextBeforeId}}"
          class="btn-card h-11 w-11 overflow-hidden rounded-lg text-(--primary)"
          th:aria-label="#{pagination.next}"
        >
          <span
            class="icon-[material-symbols--chevron-right-rounded] text-[1.75rem]"
          ></span>
        </a>
      </nav>
    </th:block>
  </section>
</MainGridLayout>
