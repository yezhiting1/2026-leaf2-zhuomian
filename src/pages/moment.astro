---
import MainGridLayout from "../layouts/MainGridLayout.astro";
---

<MainGridLayout title="${title + ' - ' + site.title}">
  <Fragment slot="head">
    <title th:text="${title + ' - ' + site.title}"></title>
  </Fragment>

  <article
    class="card-base relative z-10 mb-4 w-full overflow-hidden px-5 py-5 md:px-7 md:py-6"
    th:with="content=${moment.spec.content}"
  >
    <div class="flex items-start gap-4">
      <div class="relative shrink-0">
        <img
          alt=""
          th:if="${moment.owner != null and not #strings.isEmpty(moment.owner.avatar)}"
          th:src="${moment.owner.avatar}"
          th:alt="${moment.owner.displayName}"
          class="h-13 w-13 rounded-full object-cover ring-2 ring-(--btn-card-bg-hover)"
        />
        <span
          th:if="${moment.owner != null and not #strings.isEmpty(moment.owner.avatar)}"
          class="absolute -bottom-0.5 -right-0.5 flex h-5 w-5 items-center justify-center rounded-full bg-(--primary) text-white ring-2 ring-(--card-bg)"
        >
          <span class="icon-[material-symbols--check-small-rounded] text-base"
          ></span>
        </span>
      </div>
      <div
        th:unless="${moment.owner != null and not #strings.isEmpty(moment.owner.avatar)}"
        class="flex h-13 w-13 shrink-0 items-center justify-center rounded-full bg-(--btn-regular-bg) text-(--primary) ring-2 ring-(--btn-card-bg-hover)"
      >
        <span class="icon-[material-symbols--account-circle] text-3xl"></span>
      </div>
      <div class="min-w-0 flex-1">
        <div class="flex min-w-0 items-start justify-between gap-3">
          <div class="min-w-0">
            <h1
              class="truncate text-base font-bold text-(--primary)"
              th:text="${moment.owner != null ? moment.owner.displayName : #messages.msg('page.moments.title')}"
            >
              Moment
            </h1>
            <time
              class="mt-0.5 block text-sm text-50"
              th:datetime="${moment.spec.releaseTime}"
              th:text="${moment.spec.releaseTime != null ? #dates.format(moment.spec.releaseTime, 'MM-dd') : ''}"
              >04-25</time
            >
          </div>
          <a
            th:href="@{/moments}"
            class="btn-plain h-11 w-11 shrink-0 rounded-lg text-50 active:scale-95"
            aria-label="Back to moments"
          >
            <span class="icon-[material-symbols--arrow-back-rounded] text-2xl"
            ></span>
          </a>
        </div>

        <div
          th:if="${content != null and not #strings.isEmpty(content.html)}"
          id="content"
          class="moment-feed-content custom-md markdown-content prose prose-base mt-4 max-w-none! text-75 dark:prose-invert!"
          th:utext="${content.html}"
        >
        </div>

        <div
          th:if="${not #lists.isEmpty(moment.spec.tags)}"
          class="mt-2 flex flex-wrap gap-x-2 gap-y-1 text-base"
        >
          <a
            th:each="tagName : ${moment.spec.tags}"
            th:href="@{/moments(tag=${tagName})}"
            class="link font-medium text-(--primary)"
            th:text="${'#' + tagName}">#Tag</a
          >
        </div>

        <div
          th:if="${content != null and not #lists.isEmpty(content.medium)}"
          class="moment-media mt-4 flex max-w-full flex-wrap gap-2.5"
        >
          <div class="contents" th:each="momentItem : ${content.medium}">
            <figure
              th:if="${momentItem.type.name == 'PHOTO'}"
              class="group relative aspect-[4/5] w-40 overflow-hidden rounded-xl bg-(--btn-regular-bg) sm:w-52"
            >
              <img
                th:src="${momentItem.url}"
                alt=""
                loading="lazy"
                class="h-full w-full cursor-zoom-in object-cover transition duration-300 group-hover:scale-105"
              />
              <span
                th:if="${#lists.size(content.medium) == 1}"
                class="pointer-events-none absolute bottom-2 right-2 rounded-md bg-black/55 px-1.5 py-0.5 text-xs font-bold text-white"
                >长图</span
              >
            </figure>
            <video
              th:if="${momentItem.type.name == 'VIDEO'}"
              th:src="${momentItem.url}"
              controls
              class="max-w-full rounded-xl bg-black md:max-w-lg"></video>
            <audio
              th:if="${momentItem.type.name == 'AUDIO'}"
              th:src="${momentItem.url}"
              controls
              class="w-full max-w-lg"></audio>
            <a
              th:if="${momentItem.type.name == 'POST'}"
              th:href="${momentItem.url}"
              class="btn-regular min-h-20 max-w-full rounded-xl px-4 font-bold md:max-w-lg"
            >
              <span
                class="icon-[material-symbols--article-outline-rounded] mr-2 text-xl"
              ></span>
              <span class="truncate" th:text="${momentItem.url}">Post</span>
            </a>
          </div>
        </div>

        <div
          class="mt-4 grid grid-cols-2 border-t border-(--line-color) pt-3 text-sm text-50"
        >
          <span
            th:if="${moment.stats != null}"
            class="moment-upvote-btn flex h-10 cursor-pointer items-center gap-1.5 select-none transition hover:text-(--primary) active:scale-95"
            th:attr="data-moment=${moment.metadata.name}"
            th:data-count="${moment.stats.upvote}"
          >
            <span
              class="icon-[material-symbols--thumb-up-outline-rounded] text-xl"
            ></span>
            <span class="moment-upvote-count" th:text="${moment.stats.upvote}"
              >0</span
            >
          </span>
          <span
            th:unless="${moment.stats != null}"
            class="moment-upvote-btn flex h-10 cursor-pointer items-center gap-1.5 select-none transition hover:text-(--primary) active:scale-95"
            th:attr="data-moment=${moment.metadata.name}"
            th:data-count="0"
          >
            <span
              class="icon-[material-symbols--thumb-up-outline-rounded] text-xl"
            ></span>
            <span class="moment-upvote-count">0</span>
          </span>
          <span
            th:if="${moment.stats != null}"
            class="flex h-10 items-center justify-end gap-1.5"
          >
            <span
              class="icon-[material-symbols--chat-bubble-outline-rounded] text-xl"
            ></span>
            <span th:text="${moment.stats.approvedComment}">0</span>
          </span>
          <span
            th:unless="${moment.stats != null}"
            class="flex h-10 items-center justify-end gap-1.5"
          >
            <span
              class="icon-[material-symbols--chat-bubble-outline-rounded] text-xl"
            ></span>
            <span>0</span>
          </span>
        </div>
      </div>
    </div>
  </article>

  <style>
    .moment-feed-content :where(p) {
      margin-top: 0.35rem;
      margin-bottom: 0.35rem;
    }

    .moment-feed-content :where(a) {
      font-weight: 600;
    }
  </style>

  <div
    class="card-base relative z-10 w-full px-6 pb-4 pt-6 md:px-9"
    id="comment"
    th:if="${haloCommentEnabled}"
  >
    <h2
      class="mb-2 text-base font-medium text-gray-900 dark:text-slate-50"
      th:text="#{common.comment}"
    >
      评论
    </h2>
    <Fragment
      set:html={'<halo:comment group="moment.halo.run" kind="Moment" th:attr="name=${moment.metadata.name}" />'}
    />
  </div>

  <!-- 瞬间点赞 -->
  <script is:inline>
    document.querySelectorAll(".moment-upvote-btn").forEach(function (btn) {
      var name = btn.getAttribute("data-moment");
      var key = "fuwari-upvote-moment-" + name;
      if (localStorage.getItem(key) === "1") {
        btn.classList.add("text-(--primary)");
        btn.style.pointerEvents = "none";
      }
      btn.addEventListener("click", function () {
        if (localStorage.getItem(key) === "1") return;
        localStorage.setItem(key, "1");
        btn.classList.add("text-(--primary)");
        btn.style.pointerEvents = "none";
        var countEl = btn.querySelector(".moment-upvote-count");
        if (countEl)
          countEl.textContent = parseInt(countEl.textContent || "0", 10) + 1;
        fetch("/apis/api.halo.run/v1alpha1/trackers/upvote", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            group: "moment.halo.run",
            plural: "moments",
            name: name,
          }),
        }).catch(function () {});
      });
    });
  </script>
</MainGridLayout>
