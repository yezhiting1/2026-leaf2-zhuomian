---
import "../styles/global.css";
import "../styles/utilities.css";
import "../styles/variables.css";
import "../styles/comment-widget.css";
import "../styles/base.css";
import "../styles/components.css";
import "../styles/markdown.css";
import "../styles/transition.css";
import "../styles/scrollbar.css";
import ConfigCarrier from "../components/ConfigCarrier.astro";
import WaveEffect from "../components/WaveEffect.astro";
import "../styles/external-link-modal.css";
import {
  AUTO_MODE,
  BANNER_HEIGHT_EXTEND,
  DARK_MODE,
  DEFAULT_THEME,
  LIGHT_MODE,
  PAGE_WIDTH,
} from "../constants/constants";

interface Props {
  title?: string;
  description?: string;
  setOGTypeArticle?: boolean;
  isHomePage?: boolean;
}

const {
  title = "${site.title}",
  description = "",
  setOGTypeArticle = false,
  isHomePage = false,
} = Astro.props;

const i18nInlineScript = `<script th:inline="javascript">
  window.i18nResources = {
    "search.loading": \`[(#{search.loading})]\`,
    "search.noResults": \`[(#{search.noResults})]\`,
    "search.panel": \`[(#{search.panel})]\`,
    "search.placeholder": \`[(#{search.placeholder})]\`,
    "theme.color": \`[(#{theme.color})]\`,
    "theme.dark": \`[(#{theme.dark})]\`,
    "theme.light": \`[(#{theme.light})]\`,
    "theme.resetDefault": \`[(#{theme.resetDefault})]\`,
    "theme.system": \`[(#{theme.system})]\`,
    "nav.lightDark": \`[(#{nav.lightDark})]\`,
    "widget.music.noPlaying": \`[(#{widget.music.noPlaying})]\`,
    "widget.music.lyrics": \`[(#{widget.music.lyrics})]\`,
    "widget.music.volume": \`[(#{widget.music.volume})]\`,
    "widget.music.playMode": \`[(#{widget.music.playMode})]\`,
    "widget.music.prev": \`[(#{widget.music.prev})]\`,
    "widget.music.next": \`[(#{widget.music.next})]\`,
    "widget.music.playlist": \`[(#{widget.music.playlist})]\`,
    "widget.music.noLyrics": \`[(#{widget.music.noLyrics})]\`,
    "widget.music.loadingLyrics": \`[(#{widget.music.loadingLyrics})]\`,
    "widget.music.failedLyrics": \`[(#{widget.music.failedLyrics})]\`,
    "widget.music.noSongs": \`[(#{widget.music.noSongs})]\`,
    "widget.music.error": \`[(#{widget.music.error})]\`,
    "widget.music.play": \`[(#{widget.music.play})]\`,
    "widget.music.pause": \`[(#{widget.music.pause})]\`,
    "widget.music.progress": \`[(#{widget.music.progress})]\`,
    "widget.music.noCover": \`[(#{widget.music.noCover})]\`,
    "widget.music.cover": \`[(#{widget.music.cover})]\`,
  };
</script>`;

const themeSettingScript = `<script type="application/json" id="theme-config" th:inline="javascript">
       /*[[\${theme.config}]]*/
    </script>`;
---

<!doctype html>
<html
  th:lang="${#locale.toLanguageTag}"
  th:data-hue="${theme.config.base.themeColor.hue}"
  th:data-hue-fixed="${theme.config.base.themeColor.fixed}"
  class="bg-(--page-bg) text-[14px] transition md:text-[16px]"
  data-overlayscrollbars-initialize
>
  <head>
    <meta charset="UTF-8" />
    <!-- Guard against duplicate Custom Element registration during Swup page transitions -->
    <script>
      (function () {
        var _define = customElements.define.bind(customElements);
        customElements.define = function (name, constructor, options) {
          if (customElements.get(name)) return;
          return _define(name, constructor, options);
        };
      })();
    </script>

    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width" />
    <meta name="author" th:content="${theme.config.profile.name}" />
    <meta name="description" content={description} />
    <meta property="og:site_name" th:content="${site.title}" />
    <meta property="og:title" th:content={title} />
    <meta
      property="og:type"
      content={setOGTypeArticle ? "article" : "website"}
    />
    <meta property="og:url" th:content="${#httpServletRequest.requestURL}" />
    <title th:text={title}></title>
    <link rel="icon" th:href="${site.favicon}" />
    <link
      rel="preconnect"
      href="https://www.beian.gov.cn"
      crossorigin
      th:if="${not #strings.isEmpty(theme.config.footer.beian.gongan_text)}"
    />

    <Fragment set:html={themeSettingScript} />
    <Fragment set:html={i18nInlineScript} />
    <script
      is:inline
      define:vars={{
        DEFAULT_THEME,
        LIGHT_MODE,
        DARK_MODE,
        AUTO_MODE,
        BANNER_HEIGHT_EXTEND,
        PAGE_WIDTH,
      }}
    >
      (() => {
        const configHue = document.documentElement.dataset.hue || "250";
        const fixedHue = document.documentElement.dataset.hueFixed === "true";
        const storedTheme = localStorage.getItem("theme") || DEFAULT_THEME;
        const preferredDark = window.matchMedia(
          "(prefers-color-scheme: dark)",
        ).matches;

        if (
          storedTheme === DARK_MODE ||
          (storedTheme === AUTO_MODE && preferredDark)
        ) {
          document.documentElement.classList.add("dark");
        } else {
          document.documentElement.classList.remove("dark");
        }

        const hue = fixedHue
          ? configHue
          : localStorage.getItem("hue") || configHue;
        document.documentElement.style.setProperty("--hue", hue);
        document.documentElement.style.setProperty(
          "--page-width",
          `${PAGE_WIDTH}rem`,
        );

        // 与 constants.ts calcBannerHeightExtend 保持一致
        let offset = Math.floor(
          window.innerHeight * (BANNER_HEIGHT_EXTEND / 100),
        );
        offset = offset - (offset % 4);
        document.documentElement.style.setProperty(
          "--banner-height-extend",
          `${offset}px`,
        );

        window.__fuwariOriginalHistory ??= {
          pushState: window.history.pushState,
          replaceState: window.history.replaceState,
        };

        console.log(
          "%c🌙 Fuwari NanNan %cv1.1.1",
          "color:#8b5cf6;font-weight:bold;",
          "color:#888;",
        );
      })();
    </script>
    <slot name="head" />
  </head>
  <body
    class:list={[
      "relative min-h-screen transition",
      { "lg:is-home": isHomePage },
    ]}
    th:classappend="${(theme.config.base.banner.enable ? ' enable-banner' : '') + (theme.config.style.navbar_blur ? ' navbar-blur-enabled' : '')}"
    th:style="|--bannerOffset: ${theme.config.base.banner.position == 'top' ? '30vh' : (theme.config.base.banner.position == 'bottom' ? '0' : '15vh')};|"
    data-overlayscrollbars-initialize
  >
    <ConfigCarrier />
    <slot />
    <WaveEffect />
    <div id="page-height-extend" class="hidden h-[300vh]"></div>
    <style is:global>
      /* 移动端强制导航栏始终可见 */
      @media (max-width: 767px) {
        #navbar-wrapper {
          position: fixed !important;
          top: 0 !important;
          left: 0 !important;
          right: 0 !important;
          z-index: 50 !important;
        }
        #navbar-wrapper.navbar-hidden {
          translate: none !important;
          opacity: 1 !important;
          visibility: visible !important;
        }
        /* 防止内容被固定导航栏遮挡 */
        #top-row {
          height: 4.5rem !important;
        }
      }
    </style>
  </body>
</html>

<script>
  import "overlayscrollbars/styles/overlayscrollbars.css";
  import {
    getHue,
    getStoredTheme,
    setHue,
    setTheme,
  } from "../utils/setting-utils";

  function setClickOutsideToClose(panel: string, ignores: string[]) {
    document.addEventListener("click", (event) => {
      const panelDom = document.getElementById(panel);
      const target = event.target;
      if (!panelDom || !(target instanceof Node)) return;
      for (const ignored of ignores) {
        const ignoredEl = document.getElementById(ignored);
        if (ignoredEl === target || ignoredEl?.contains(target)) return;
      }
      panelDom.classList.add("float-panel-closed");
    });
  }

  // 延迟加载自定义滚动条，不阻塞首屏渲染
  let scrollbarInitialized = false;
  function initCustomScrollbar() {
    if (scrollbarInitialized) return;
    scrollbarInitialized = true;
    const bodyElement = document.querySelector("body");
    if (!bodyElement) return;
    import("overlayscrollbars").then(({ OverlayScrollbars }) => {
      OverlayScrollbars(
        {
          target: bodyElement,
          cancel: { nativeScrollbarsOverlaid: true },
        },
        {
          scrollbars: {
            theme: "scrollbar-base scrollbar-auto py-1",
            autoHide: "move",
            autoHideDelay: 500,
            autoHideSuspend: false,
          },
        },
      );
    });
  }

  function showBanner() {
    const banner = document.getElementById("banner");
    if (!banner) return;
    const img = banner.querySelector("img");
    if (img) {
      if (img.complete && img.naturalWidth > 0) {
        banner.classList.remove("opacity-0", "scale-105");
      } else {
        img.onload = () => banner.classList.remove("opacity-0", "scale-105");
        img.onerror = () => banner.classList.remove("opacity-0", "scale-105");
      }
    } else {
      banner.classList.remove("opacity-0", "scale-105");
    }
  }

  function getPathname(url: string) {
    try {
      return new URL(url, window.location.origin).pathname;
    } catch {
      // split 永远返回数组，[0] 总存在（至少是 ""），"" 是 falsy 需要 || "/" 兜底
      return url.split("?")[0].split("#")[0] || "/";
    }
  }

  import { syncHomeClass, scrollFunction } from "../utils/scroll-manager";

  import { initLegacyAdmonitions } from "../utils/legacy-admonitions";

  function init() {
    syncHomeClass();
    setTheme(getStoredTheme());
    setHue(getHue());
    initCustomScrollbar();
    showBanner();
    initLegacyAdmonitions();
    // 懒加载音乐播放器 CSS（仅在页面含有音乐播放器时加载）
    if (document.querySelector(".firefly-music-player")) {
      import("../styles/music-player.css");
    }
  }

  setClickOutsideToClose("display-setting", [
    "display-setting",
    "display-settings-switch",
  ]);
  setClickOutsideToClose("nav-menu-panel", [
    "nav-menu-panel",
    "nav-menu-switch",
  ]);
  setClickOutsideToClose("search-panel", [
    "search-panel",
    "search-bar",
    "search-switch",
  ]);
  init();

  import {
    initContentLightbox,
    initPhotosGallery,
    destroyAll,
  } from "../utils/content-media";

  void initContentLightbox();
  void initPhotosGallery();

  function restoreOriginalHistoryStateHandlers() {
    const originalHistory = window.__fuwariOriginalHistory;
    if (!originalHistory) return;

    if (originalHistory.pushState) {
      window.history.pushState = originalHistory.pushState;
    }
    if (originalHistory.replaceState) {
      window.history.replaceState = originalHistory.replaceState;
    }
  }

  const setupSwup = () => {
    if (window.__fuwariSwupHandlersBound) return;
    window.__fuwariSwupHandlersBound = true;

    window.swup.hooks.on("link:click", () => {
      document.documentElement.style.setProperty("--content-delay", "0ms");
    });
    window.swup.hooks.on("content:replace", initCustomScrollbar);
    window.swup.hooks.on("content:replace", destroyAll, { before: true });
    // 右侧边栏 TOC 手动刷新（确保 swup 替换后 TOC 重新初始化高亮追踪）
    window.swup.hooks.on("content:replace", () => {
      const rightToc = document.querySelector(
        "#right-sidebar table-of-contents",
      ) as (HTMLElement & { refresh?: () => void }) | null;
      if (rightToc?.refresh) {
        rightToc.refresh();
      }
    });
    window.swup.hooks.on("page:view", () => {
      syncHomeClass();
      void initContentLightbox();
      void initPhotosGallery();
      showBanner();
      scrollFunction();
      initLegacyAdmonitions();
      initExternalLinkRedirect();
      if (document.querySelector(".firefly-music-player")) {
        import("../styles/music-player.css");
      }
    });
    window.swup.hooks.on("visit:start", (visit: { to?: { url?: string } }) => {
      restoreOriginalHistoryStateHandlers();
      if (visit.to?.url) {
        syncHomeClass(getPathname(visit.to.url));
      }
      document.getElementById("page-height-extend")?.classList.remove("hidden");
      document.getElementById("toc-wrapper")?.classList.add("toc-not-ready");
    });
    window.swup.hooks.on("visit:end", () => {
      setTimeout(() => {
        document.getElementById("page-height-extend")?.classList.add("hidden");
        document
          .getElementById("toc-wrapper")
          ?.classList.remove("toc-not-ready");
      }, 200);
    });
  };

  if (window?.swup?.hooks) {
    setupSwup();
  } else {
    document.addEventListener("swup:enable", setupSwup);
  }

  scrollFunction();

  import { initExternalLinkRedirect } from "../utils/external-link-redirect";

  initExternalLinkRedirect();
</script>
