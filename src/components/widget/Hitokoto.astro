---
import WidgetLayout from "./WidgetLayout.astro";

interface Props {
  class?: string;
}

const className = Astro.props.class;
---

<WidgetLayout
  name="一言"
  nameKey="widget.hitokoto.title"
  id="hitokoto"
  class={className}
>
  <style>
    .hitokoto-card {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif;
      line-height: 1.6;
      max-width: 100%;
      box-sizing: border-box;
    }

    .hitokoto-main-row {
      display: flex;
      align-items: flex-start;
      gap: 10px;
    }

    .hitokoto-text {
      flex: 1;
      min-width: 0;
      font-size: 14px;
      color: var(--text-90, #333);
      word-break: break-word;
      margin: 0;
      transition: opacity 0.3s ease;
    }

    .hitokoto-refresh {
      flex-shrink: 0;
      width: 26px;
      height: 26px;
      border: none;
      background: transparent;
      cursor: pointer;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #bbb;
      transition: color 0.2s, background 0.2s;
      padding: 0;
      margin-top: 1px;
    }

    .hitokoto-refresh:hover {
      color: var(--text-30, #666);
      background: rgba(0, 0, 0, 0.04);
    }

    .hitokoto-refresh:active {
      transform: scale(0.9);
    }

    .hitokoto-refresh svg {
      width: 15px;
      height: 15px;
      transition: transform 0.4s ease;
    }

    .hitokoto-refresh.spinning svg {
      transform: rotate(360deg);
    }

    .hitokoto-author-row {
      margin-top: 6px;
    }

    .hitokoto-author {
      font-size: 12px;
      color: var(--text-50, #999);
      display: block;
      text-align: right;
    }

    .hitokoto-author::before {
      content: "—— ";
    }

    .hitokoto-loading .hitokoto-text {
      opacity: 0.5;
    }
  </style>

  <div class="hitokoto-card" id="hitokotoCard">
    <div class="hitokoto-main-row">
      <p class="hitokoto-text" id="hitokotoText">加载中...</p>
      <button class="hitokoto-refresh" id="hitokotoRefresh" title="换一句">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="23 4 23 10 17 10"></polyline>
          <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path>
        </svg>
      </button>
    </div>
    <div class="hitokoto-author-row">
      <span class="hitokoto-author" id="hitokotoAuthor"></span>
    </div>
  </div>
</WidgetLayout>

<script is:inline>
  (function() {
    var hitokotoInitialized = false;

    function initHitokoto() {
      if (hitokotoInitialized) return;
      var card = document.getElementById('hitokotoCard');
      if (!card) return;
      hitokotoInitialized = true;

      var textEl = document.getElementById('hitokotoText');
      var authorEl = document.getElementById('hitokotoAuthor');
      var refreshBtn = document.getElementById('hitokotoRefresh');

      var API = 'https://v1.hitokoto.cn/';

      function fetchHitokoto() {
        return fetch(API, { signal: AbortSignal.timeout(5000) })
          .then(function(resp) {
            if (resp.ok) return resp.json();
            throw new Error('Network response was not ok.');
          })
          .then(function(data) {
            return {
              content: data.hitokoto || data.content || '',
              author: data.from || data.author || data.source || ''
            };
          })
          .catch(function(e) {
            console.warn('一言获取失败，使用默认句子', e.message);
            return {
              content: '世界很大，开心第一。',
              author: '楠南NanNan'
            };
          });
      }

      function updateCard(data) {
        textEl.textContent = data.content;
        authorEl.textContent = data.author || '';
        card.classList.remove('hitokoto-loading');
      }

      function refresh() {
        card.classList.add('hitokoto-loading');
        refreshBtn.classList.add('spinning');
        fetchHitokoto().then(function(data) {
          updateCard(data);
          setTimeout(function() {
            refreshBtn.classList.remove('spinning');
          }, 400);
        });
      }

      refreshBtn.addEventListener('click', refresh);
      refresh();
    }

    // 初始化
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initHitokoto);
    } else {
      initHitokoto();
    }

    // Swup 页面切换后重新初始化
    if (typeof window.swup !== 'undefined') {
      window.swup.on('contentReplaced', function() {
        hitokotoInitialized = false;
        setTimeout(initHitokoto, 100);
      });
    }
  })();
</script>
