---
interface Props {
  id: string;
  name?: string;
  nameKey?: string;
  nameExpression?: string;
  isCollapsed?: boolean;
  collapseExpression?: string;
  collapsedHeight?: string;
  class?: string;
  style?: string;
}

const {
  id,
  name,
  nameKey,
  nameExpression,
  isCollapsed = false,
  collapseExpression,
  collapsedHeight = "7.5rem",
  style,
} = Astro.props;
const className = Astro.props.class;
const hasRuntimeCollapse = Boolean(collapseExpression);
const collapseCondition = collapseExpression
  ? `\${${collapseExpression}}`
  : undefined;
const collapseClassAppend = collapseExpression
  ? `\${${collapseExpression}} ? 'collapsed' : ''`
  : undefined;
const collapseDataAttr = collapseExpression
  ? `data-is-collapsed=\${${collapseExpression}}`
  : undefined;
const titleText = nameExpression
  ? `\${${nameExpression}}`
  : nameKey
    ? `#{${nameKey}}`
    : undefined;
---

<widget-layout
  data-id={id}
  data-is-collapsed={String(isCollapsed && !hasRuntimeCollapse)}
  th:attr={collapseDataAttr}
  class:list={["card-base pb-4", className]}
  style={style}
>
  <div
    class="relative mb-2 ml-8 mt-4 text-lg font-bold text-neutral-900 transition before:absolute before:left-[-16px] before:top-[5.5px] before:h-4 before:w-1 before:rounded-md before:bg-(--primary) dark:text-neutral-100"
    th:text={titleText}
  >
    {name}
  </div>
  <div
    id={id}
    th:classappend={collapseClassAppend}
    class:list={[
      "collapse-wrapper overflow-hidden px-4",
      { collapsed: isCollapsed && !hasRuntimeCollapse },
    ]}
  >
    <slot />
  </div>
  {
    (isCollapsed || hasRuntimeCollapse) && (
      <div class="expand-btn -mb-2 px-4" th:if={collapseCondition}>
        <button class="btn-plain h-9 w-full rounded-lg" type="button">
          <div class="-translate-x-2 flex items-center justify-center gap-2 text-(--primary)">
            <span class="icon-[material-symbols--more-horiz] text-[1.75rem]" />
            <span th:text="#{common.more}">More</span>
          </div>
        </button>
      </div>
    )
  }
</widget-layout>

<style define:vars={{ collapsedHeight }}>
  .collapsed {
    height: var(--collapsedHeight);
  }
</style>

<script>
  class WidgetLayout extends HTMLElement {
    connectedCallback() {
      if (this.dataset.isCollapsed !== "true") return;
      const id = this.dataset.id;
      const btn = this.querySelector(".expand-btn");
      const wrapper = this.querySelector(`#${id}`);
      btn?.addEventListener("click", () => {
        wrapper?.classList.remove("collapsed");
        btn.classList.add("hidden");
      });
    }
  }

  if (!customElements.get("widget-layout")) {
    customElements.define("widget-layout", WidgetLayout);
  }
</script>
