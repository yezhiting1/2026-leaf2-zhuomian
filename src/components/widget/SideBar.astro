---
import Categories from "./Categories.astro";
import Hitokoto from "./Hitokoto.astro";
import MusicPlayer from "./MusicPlayer.astro";
import Profile from "./Profile.astro";
import SiteStats from "./SiteStats.astro";
import Tags from "./Tags.astro";
import Weather from "./Weather.astro";

interface Props {
  class?: string;
}

const className = Astro.props.class;
const thClassappend = Astro.props["th:classappend"] || "";
---

<aside
  id="sidebar"
  class:list={[className, "w-full"]}
  th:classappend={thClassappend}
>
  <div class="mb-4 flex w-full flex-col gap-4">
    <Profile />
  </div>
  <div id="sidebar-sticky" class="sticky top-4 flex w-full flex-col gap-4">
    <div
      class="contents"
      th:each="widget, widgetStat : ${theme.config.sidebar.widgets}"
    >
      <div class="contents" th:switch="${widget.value}">
        <div class="contents" th:case="'categories'">
          <Categories class="onload-animation" />
        </div>
        <div class="contents" th:case="'tag'">
          <Tags class="onload-animation" />
        </div>
        <div class="contents" th:case="'music'">
          <MusicPlayer
            class="onload-animation"
            th:style="|animation-delay: calc(var(--content-delay) + ${widgetStat.index * 50}ms)|"
          />
        </div>
        <div class="contents" th:case="'hitokoto'">
          <Hitokoto class="onload-animation" />
        </div>
        <div class="contents" th:case="'site-stats'">
          <SiteStats class="onload-animation" />
        </div>
        <div class="contents" th:case="'weather'">
          <Weather
            class="onload-animation"
            th:style="|animation-delay: calc(var(--content-delay) + ${widgetStat.index * 50}ms)|"
          />
        </div>
        <div
          th:case="'html'"
          class="card-base onload-animation p-4"
          th:utext="${widget.html}"
        >
        </div>
      </div>
    </div>
  </div>
</aside>
