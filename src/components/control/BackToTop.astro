---
import { Icon } from "astro-icon/components";
---

<!-- There can't be a filter on parent element, or it will break `fixed` -->
<div class="back-to-top-wrapper hidden lg:block">
  <div
    id="back-to-top-btn"
    class="back-to-top-btn hide flex items-center rounded-2xl overflow-hidden transition"
    onclick="backToTop()"
  >
    <button
      th:aria-label="#{fragment.layout.toTop}"
      aria-label="Back to Top"
      class="btn-card h-[3.75rem] w-[3.75rem]"
      th:classappend="${theme.config.style.navbar_blur} ? '!bg-(--card-bg)/70 backdrop-blur-lg' : ''"
    >
      <Icon name="material-symbols:keyboard-arrow-up-rounded" class="mx-auto" />
    </button>
  </div>
</div>

<style lang="stylus">
  .back-to-top-wrapper
    width: 3.75rem
    height: 3.75rem
    position: absolute
    right: 0
    top: 0
    pointer-events: none

  .back-to-top-btn
    color: var(--primary)
    font-size: 2.25rem
    font-weight: bold
    border: none
    position: fixed
    top: 4.5rem
    right: 0.75rem
    opacity: 1
    cursor: pointer
    transform: translateX(0)
    pointer-events: auto
    transition: transform 0.3s ease, opacity 0.3s ease
    i
      font-size: 1.75rem
    &.hide
      transform: translateX(5rem)
      opacity: 0
      pointer-events: none
    &:active
      transform: scale(0.9)

  /* 三栏布局：按钮紧贴右侧边栏左边缘，不遮挡小组件 */
  @media (min-width: 1280px)
    .back-to-top-btn
      right: calc((100vw - 75rem) / 2 + 17.5rem + 1rem)

</style>

<script is:raw is:inline>
  function backToTop() {
    window.scroll({ top: 0, behavior: "smooth" });
  }
</script>
