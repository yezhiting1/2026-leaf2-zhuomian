    "page.photos.exif.dimensions": \`[(#{page.photos.exif.dimensions})]\`,
    "page.photos.exif.focalLength": \`[(#{page.photos.exif.focalLength})]\`,
    "page.photos.exif.iso": \`[(#{page.photos.exif.iso})]\`,
    "page.photos.exif.lens": \`[(#{page.photos.exif.lens})]\`,
    "page.photos.exif.shutter": \`[(#{page.photos.exif.shutter})]\`,
    "page.photos.more": \`[(#{page.photos.more})]\`,
    "page.photos.selectPhoto": \`[(#{page.photos.selectPhoto})]\`,
